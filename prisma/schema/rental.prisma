enum RentalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  ACTIVE
}


model RentalRequest {
  id               String              @id @default(uuid())
  moveInDate       DateTime
  durationMonths   Int
  message          String?
  monthlyRent      Decimal             @db.Decimal(10, 2)
  status           RentalRequestStatus @default(PENDING)
  propertyId       String
  tenantId         String
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  property         Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           User                @relation("TenantRentalRequests", fields: [tenantId], references: [id], onDelete: Cascade)
  payment          Payment?
  review           Review?

  @@unique([propertyId, tenantId, moveInDate])
  @@index([tenantId])
  @@index([propertyId])
}
